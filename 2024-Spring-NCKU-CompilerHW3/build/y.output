未在文法中使用終結語詞

    THEN


文法

    0 $accept: Program $end

    1 $@1: ε

    2 Program: $@1 GlobalStmtList
    3        | ε

    4 GlobalStmtList: GlobalStmtList GlobalStmt
    5               | GlobalStmt

    6 GlobalStmt: DefineVariableStmt ';'
    7           | FunctionDefStmt

    8 DefineVariableStmt: VARIABLE_T DefineVariableList

    9 DefineVariableList: DefineVariableList ',' DefineVariable
   10                   | DefineVariable

   11 DefineVariable: IDENT
   12               | IDENT VAL_ASSIGN Expression
   13               | IDENT '[' Literal ']'

   14 $@2: ε

   15 DefineVariable: IDENT '[' Literal ']' $@2 VAL_ASSIGN '{' ExpList '}'
   16               | IDENT '[' Literal ']' '[' Literal ']'

   17 $@3: ε

   18 $@4: ε

   19 FunctionDefStmt: VARIABLE_T IDENT '(' $@3 FunctionParameterStmtList ')' $@4 '{' StmtList '}'

   20 FunctionParameterStmtList: FunctionParameterStmtList ',' FunctionParameterStmt
   21                          | FunctionParameterStmt
   22                          | ε

   23 FunctionParameterStmt: VARIABLE_T IDENT
   24                      | VARIABLE_T IDENT '[' ']'

   25 StmtList: StmtList Stmt
   26         | Stmt

   27 Stmt: ';'
   28     | COUT CoutParmListStmt ';'
   29     | RETURN Expression ';'
   30     | RETURN ';'
   31     | BREAK ';'
   32     | CONTINUE ';'
   33     | DefineVariableStmt ';'
   34     | AssignStmt ';'
   35     | FuncCallStmt ';'
   36     | IfStmt
   37     | ForStmt
   38     | WhileStmt

   39 CoutParmListStmt: CoutParmListStmt SHL ENDL
   40                 | CoutParmListStmt SHL Expression
   41                 | SHL Expression

   42 $@5: ε

   43 $@6: ε

   44 IfStmt: IF '(' Expression ')' $@5 '{' StmtList '}' $@6 ElseStmt

   45 $@7: ε

   46 IfStmt: IF '(' Expression ')' $@7 Stmt

   47 $@8: ε

   48 ElseStmt: ELSE $@8 '{' StmtList '}'
   49         | ε

   50 $@9: ε

   51 ForStmt: FOR $@9 '(' ForInitStmt ')' '{' StmtList '}'

   52 ForInitStmt: DefineVariableStmt ':' Expression
   53            | ForCondStmt ';' Expression ';' ForUpdateStmt

   54 ForCondStmt: DefineVariableStmt
   55            | AssignStmt
   56            | ε

   57 ForUpdateStmt: AssignStmt
   58              | ε

   59 $@10: ε

   60 $@11: ε

   61 WhileStmt: WHILE $@10 '(' Expression ')' $@11 '{' StmtList '}'

   62 $@12: ε

   63 AssignStmt: IdentExp VAL_ASSIGN $@12 Expression

   64 $@13: ε

   65 AssignStmt: IdentExp ADD_ASSIGN $@13 Expression

   66 $@14: ε

   67 AssignStmt: IdentExp SUB_ASSIGN $@14 Expression

   68 $@15: ε

   69 AssignStmt: IdentExp MUL_ASSIGN $@15 Expression

   70 $@16: ε

   71 AssignStmt: IdentExp DIV_ASSIGN $@16 Expression

   72 $@17: ε

   73 AssignStmt: IdentExp REM_ASSIGN $@17 Expression

   74 $@18: ε

   75 AssignStmt: IdentExp SHR_ASSIGN $@18 Expression

   76 $@19: ε

   77 AssignStmt: IdentExp SHL_ASSIGN $@19 Expression

   78 $@20: ε

   79 AssignStmt: IdentExp BAN_ASSIGN $@20 Expression

   80 $@21: ε

   81 AssignStmt: IdentExp BOR_ASSIGN $@21 Expression

   82 $@22: ε

   83 AssignStmt: IdentExp BXO_ASSIGN $@22 Expression
   84           | IdentExp INC_ASSIGN
   85           | IdentExp DEC_ASSIGN

   86 ExpList: ExpList ',' Expression
   87        | Expression
   88        | ε

   89 Expression: ExpHierarchy

   90 ExpHierarchy: LORExp

   91 LORExp: LORExp LOR LANExp
   92       | LANExp

   93 LANExp: LANExp LAN BORExp
   94       | BORExp

   95 BORExp: BORExp BOR BXOExp
   96       | BXOExp

   97 BXOExp: BXOExp BXO BANExp
   98       | BANExp

   99 BANExp: BANExp BAN EQUExp
  100       | EQUExp

  101 EQUExp: EQUExp EQL CompareExp
  102       | EQUExp NEQ CompareExp
  103       | CompareExp

  104 CompareExp: CompareExp GTR ShiftExp
  105           | CompareExp LES ShiftExp
  106           | CompareExp GEQ ShiftExp
  107           | CompareExp LEQ ShiftExp
  108           | ShiftExp

  109 ShiftExp: ShiftExp SHR AddSubExp
  110         | AddSubExp

  111 AddSubExp: AddSubExp ADD MulExp
  112          | AddSubExp SUB MulExp
  113          | MulExp

  114 MulExp: MulExp MUL UnaryExp
  115       | MulExp DIV UnaryExp
  116       | MulExp REM UnaryExp
  117       | UnaryExp

  118 UnaryExp: NOT UnaryExp
  119         | BNT UnaryExp
  120         | SUB UnaryExp
  121         | '(' VARIABLE_T ')' UnaryExp
  122         | FuncCallStmt
  123         | Literal

  124 FuncCallStmt: IDENT '(' ExpList ')'

  125 Literal: STR_LIT
  126        | INT_LIT
  127        | FLOAT_LIT
  128        | BOOL_LIT
  129        | CHAR_LIT
  130        | '(' Expression ')'
  131        | IdentExp

  132 IdentExp: IDENT
  133         | IDENT '[' Expression ']'
  134         | IDENT '[' Expression ']' '[' Expression ']'


