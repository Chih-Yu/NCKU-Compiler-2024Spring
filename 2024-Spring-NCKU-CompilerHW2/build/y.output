   16               | IDENT . '[' Literal ']' '[' Literal ']'
   19 FunctionDefStmt: VARIABLE_T IDENT . '(' @3 FunctionParameterStmtList ')' @4 '{' StmtList '}'

    VAL_ASSIGN  shift, and go to state 14
    '['         shift, and go to state 15
    '('         shift, and go to state 16

    $default  reduce using rule 11 (DefineVariable)


state 10

