Grammar

    0 $accept: Program $end

    1 @1: /* empty */

    2 Program: @1 GlobalStmtList
    3        | /* empty */

    4 GlobalStmtList: GlobalStmtList GlobalStmt
    5               | GlobalStmt

    6 GlobalStmt: DefineVariableStmt ';'
    7           | FunctionDefStmt

    8 DefineVariableStmt: VARIABLE_T DefineVariableList

    9 DefineVariableList: DefineVariableList ',' DefineVariable
   10                   | DefineVariable

   11 DefineVariable: IDENT
   12               | IDENT VAL_ASSIGN Expression
   13               | IDENT '[' Literal ']'

   14 @2: /* empty */

   15 DefineVariable: IDENT '[' Literal ']' @2 VAL_ASSIGN '{' ExpList '}'
   16               | IDENT '[' Literal ']' '[' Literal ']'

   17 @3: /* empty */

   18 @4: /* empty */

   19 FunctionDefStmt: VARIABLE_T IDENT '(' @3 FunctionParameterStmtList ')' @4 '{' StmtList '}'

   20 FunctionParameterStmtList: FunctionParameterStmtList ',' FunctionParameterStmt
   21                          | FunctionParameterStmt
   22                          | /* empty */

   23 FunctionParameterStmt: VARIABLE_T IDENT
   24                      | VARIABLE_T IDENT '[' ']'

   25 StmtList: StmtList Stmt
   26         | Stmt

   27 Stmt: ';'
   28     | COUT CoutParmListStmt ';'
   29     | RETURN Expression ';'
   30     | RETURN ';'
   31     | BREAK ';'
   32     | CONTINUE ';'
   33     | DefineVariableStmt ';'
   34     | AssignStmt ';'
   35     | FuncCallStmt ';'
   36     | IfStmt
   37     | ForStmt
   38     | WhileStmt

   39 CoutParmListStmt: CoutParmListStmt SHL Expression
   40                 | SHL Expression

   41 @5: /* empty */

   42 @6: /* empty */

   43 IfStmt: IF '(' Expression ')' @5 '{' StmtList '}' @6 ElseStmt

   44 @7: /* empty */

   45 IfStmt: IF '(' Expression ')' @7 Stmt

   46 @8: /* empty */

   47 ElseStmt: ELSE @8 '{' StmtList '}'
   48         | /* empty */

   49 @9: /* empty */

   50 ForStmt: FOR @9 '(' ForInitStmt ')' '{' StmtList '}'

   51 ForInitStmt: DefineVariableStmt ':' Expression
   52            | ForCondStmt ';' Expression ';' ForUpdateStmt

   53 ForCondStmt: DefineVariableStmt
   54            | AssignStmt
   55            | /* empty */

   56 ForUpdateStmt: AssignStmt
   57              | /* empty */

   58 @10: /* empty */

   59 @11: /* empty */

   60 WhileStmt: WHILE @10 '(' Expression ')' @11 '{' StmtList '}'

   61 AssignStmt: IdentExp VAL_ASSIGN Expression
   62           | IdentExp ADD_ASSIGN Expression
   63           | IdentExp SUB_ASSIGN Expression
   64           | IdentExp MUL_ASSIGN Expression
   65           | IdentExp DIV_ASSIGN Expression
   66           | IdentExp REM_ASSIGN Expression
   67           | IdentExp SHR_ASSIGN Expression
   68           | IdentExp SHL_ASSIGN Expression
   69           | IdentExp BAN_ASSIGN Expression
   70           | IdentExp BOR_ASSIGN Expression
   71           | IdentExp BXO_ASSIGN Expression
   72           | IdentExp INC_ASSIGN
   73           | IdentExp DEC_ASSIGN

   74 ExpList: ExpList ',' Expression
   75        | Expression
   76        | /* empty */

   77 Expression: ExpHierarchy

   78 ExpHierarchy: LORExp

   79 LORExp: LORExp LOR LANExp
   80       | LANExp

   81 LANExp: LANExp LAN BORExp
   82       | BORExp

   83 BORExp: BORExp BOR BXOExp
   84       | BXOExp

   85 BXOExp: BXOExp BXO BANExp
   86       | BANExp

   87 BANExp: BANExp BAN EQUExp
   88       | EQUExp

   89 EQUExp: EQUExp EQL CompareExp
   90       | EQUExp NEQ CompareExp
   91       | CompareExp

   92 CompareExp: CompareExp GTR ShiftExp
   93           | CompareExp LES ShiftExp
   94           | CompareExp GEQ ShiftExp
   95           | CompareExp LEQ ShiftExp
   96           | ShiftExp

   97 ShiftExp: ShiftExp SHR AddSubExp
   98         | AddSubExp

   99 AddSubExp: AddSubExp ADD MulExp
  100          | AddSubExp SUB MulExp
  101          | MulExp

  102 MulExp: MulExp MUL UnaryExp
  103       | MulExp DIV UnaryExp
  104       | MulExp REM UnaryExp
  105       | UnaryExp

  106 UnaryExp: NOT UnaryExp
  107         | BNT UnaryExp
  108         | SUB UnaryExp
  109         | '(' VARIABLE_T ')' UnaryExp
  110         | FuncCallStmt
  111         | Literal

  112 FuncCallStmt: IDENT '(' ExpList ')'

  113 Literal: STR_LIT
  114        | INT_LIT
  115        | FLOAT_LIT
  116        | BOOL_LIT
  117        | '(' Expression ')'
  118        | IdentExp

  119 IdentExp: IDENT
  120         | IDENT '[' Expression ']'
  121         | IDENT '[' Expression ']' '[' Expression ']'


